generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Booking {
  id                String   @id @default(uuid())

  // --- פרטי צד א' (חובה) ---
  clientAFullName   String
  clientAIdNumber   String
  clientAPhone      String
  clientAEmail      String?
  clientAAddress    String?

  // --- פרטי צד ב' (רשות) ---
  clientBFullName   String?
  clientBIdNumber   String?
  clientBPhone      String?
  clientBEmail      String?
  clientBAddress    String?

  // --- פרטי האירוע ---
  calendarDateId    String    @unique
  eventDate         EventDate @relation(fields: [calendarDateId], references: [id])
  
  eventType         String
  timeOfDay         String?
  guestCount        Int
  finalPricePortion Float

  // --- הערות ---
  managerComments   String?
  clientComments    String?

  // --- כספים, אקו"ם וחוזים ---
  totalPrice          Float
  paidAmount          Float    @default(0)
  paymentStatus       String   @default("pending")
  
  eventCode           String   @unique @default(cuid()) // קוד אירוע סודי לכניסת הלקוח
  hasMusic            Boolean  @default(true)           // האם האירוע כולל מוזיקה
  akumApprovalCode    String?                           // קוד אישור מאקו"ם
  advancePaid         Float    @default(0)              // מקדמה ששולמה
  totalPaid           Float    @default(0)              // סך הכל שולם
  securityCheckStatus String   @default("PENDING")      // סטטוס צ'ק ביטחון
  securityCheckUrl    String?                           // קישור לתמונה של צ'ק הביטחון
  isContractSigned    Boolean  @default(false)          // האם חוזה נחתם

  // --- היסטוריה ולוגים ---
  createdAt         DateTime @default(now())
  createdBy         String
  updatedAt         DateTime @updatedAt
  updatedBy         String?
}

// מודל לקטגוריות בתפריט
model MenuCategory {
  id     String @id @default(uuid())
  name   String 
  dishes Dish[] 
}

// מודל למנה בודדת בתפריט
model Dish {
  id          String       @id @default(uuid())
  name        String
  description String?
  price       Float?
  categoryId  String
  category    MenuCategory @relation(fields: [categoryId], references: [id])
}

// מודל לתאריכים ואופציות בלוח השנה
model EventDate {
  id              String    @id @default(uuid())
  date            DateTime  @unique
  status          String    // AVAILABLE, BOOKED, BLOCKED, OPTION
  lockedBy        String?
  booking         Booking?

  // --- פרטי הלקוח ששומר אופציה זמנית ---
  clientName      String?
  clientPhone     String?
  clientEmail     String?
  optionExpiresAt DateTime? // שעת הפקיעה של האופציה
}