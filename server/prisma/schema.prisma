// server/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Booking {
  id                String   @id @default(uuid())

  // --- פרטי צד א' (חובה) ---
  clientAFullName   String
  clientAIdNumber   String
  clientAPhone      String
  clientAEmail      String?
  clientAAddress    String?

  // --- פרטי צד ב' (רשות) ---
  clientBFullName   String?
  clientBIdNumber   String?
  clientBPhone      String?
  clientBEmail      String?
  clientBAddress    String?

  // --- פרטי האירוע ---
  calendarDateId    String   @unique
  eventDate         EventDate @relation(fields: [calendarDateId], references: [id])
  
  eventType         String
  timeOfDay         String?
  guestCount        Int
  finalPricePortion Float

  // --- הערות ---
  managerComments   String?
  clientComments    String?

  // --- כספים ---
  totalPrice        Float
  paidAmount        Float    @default(0)
  paymentStatus     String   @default("pending")

  // --- היסטוריה ולוגים ---
  createdAt         DateTime @default(now())
  createdBy         String
  updatedAt         DateTime @updatedAt
  updatedBy         String?
}

// מודל לקטגוריות
model MenuCategory {
  id     String @id @default(uuid())
  name   String 
  dishes Dish[] 
}

// מודל למנה בודדת
model Dish {
  id          String       @id @default(uuid())
  name        String
  description String?
  price       Float?
  categoryId  String
  category    MenuCategory @relation(fields: [categoryId], references: [id])
}

// מודל לתאריכים ואופציות - מאוחד ומתוקן
model EventDate {
  id              String    @id @default(uuid())
  date            DateTime  @unique
  status          String    // AVAILABLE, BOOKED, BLOCKED, OPTION etc.
  lockedBy        String?

  booking         Booking?

  // --- פרטי הלקוח ששומר אופציה ---
  clientName      String?
  clientPhone     String?
  clientEmail     String?

  // --- תשתית ניהול אופציות מתקדמת (חדש) ---
  optionExpiresAt DateTime? // שעת הפקיעה של האופציה
}