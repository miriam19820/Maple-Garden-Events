generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Booking {
  id                String    @id @default(uuid())

  // --- פרטי צד א' (חובה) ---
  clientAFullName   String
  clientAIdNumber   String
  clientAPhone      String
  clientAEmail      String?
  clientAAddress    String?

  // --- פרטי צד ב' (רשות) ---
  clientBFullName   String?
  clientBIdNumber   String?
  clientBPhone      String?
  clientBEmail      String?
  clientBAddress    String?

  // --- פרטי האירוע ---
  calendarDateId    String
  eventDate         EventDate @relation(fields: [calendarDateId], references: [id])
  
  eventType         String
  timeOfDay         String    // "בוקר", "צהריים", "ערב"
  guestCount        Int
  finalPricePortion Float

  // --- הערות ---
  managerComments   String?
  clientComments    String?

  // --- כספים, אקו"ם וחוזים ---
  totalPrice          Float
  paidAmount          Float    @default(0)
  paymentStatus       String   @default("pending")
  
  eventCode           String   @unique @default(cuid())
  hasMusic            Boolean  @default(true)
  akumApprovalCode    String?
  advancePaid         Float    @default(0)
  totalPaid           Float    @default(0)
  securityCheckStatus String   @default("PENDING")
  securityCheckUrl    String?
  isContractSigned    Boolean  @default(false)

  // --- היסטוריה ולוגים ---
  createdAt         DateTime @default(now())
  createdBy         String
  updatedAt         DateTime @updatedAt
  updatedBy         String?

  // מונע מלקוח להזמין פעמיים את אותו סוג זמן באותו תאריך
  @@unique([calendarDateId, timeOfDay])
}

model MenuCategory {
  id     String @id @default(uuid())
  name   String 
  dishes Dish[] 
}

model Dish {
  id          String       @id @default(uuid())
  name        String
  description String?
  price       Float?
  categoryId  String
  category    MenuCategory @relation(fields: [categoryId], references: [id])
}
model EventDate {
  id              String    @id @default(uuid())
  date            DateTime  
  status          String    
  lockedBy        String?
  bookings        Booking[] 

  clientName      String?
  clientPhone     String?
  clientEmail     String?
  optionExpiresAt DateTime?

  // הגדרת Unique עם שם מפורש כדי למנוע התנגשויות
  @@unique([date], map: "unique_date_constraint")
}