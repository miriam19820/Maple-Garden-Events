generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Booking {
  id                String   @id @default(uuid())

  // --- פרטי צד א' (חובה) ---
  clientAFullName   String
  clientAIdNumber   String
  clientAPhone      String
  clientAEmail      String?
  clientAAddress    String?

  // --- פרטי צד ב' (רשות) ---
  clientBFullName   String?
  clientBIdNumber   String?
  clientBPhone      String?
  clientBEmail      String?
  clientBAddress    String?

  // --- פרטי האירוע ---
  calendarDateId    String    @unique
  eventDate         EventDate @relation(fields: [calendarDateId], references: [id])
  
  eventType         String
  timeOfDay         String?
  guestCount        Int
  finalPricePortion Float

  // --- הערות ---
  managerComments   String?
  clientComments    String?

  // --- כספים, אקו"ם וחוזים ---
  totalPrice          Float
  paidAmount          Float    @default(0)
  paymentStatus       String   @default("pending")
  
  eventCode           String   @unique @default(cuid()) // קוד אירוע סודי לכניסת הלקוח
  hasMusic            Boolean  @default(true)           // האם האירוע כולל מוזיקה
  akumApprovalCode    String?                           // קוד אישור מאקו"ם
  advancePaid         Float    @default(0)              // מקדמה ששולמה
  totalPaid           Float    @default(0)              // סך הכל שולם
  securityCheckStatus String   @default("PENDING")      // סטטוס צ'ק ביטחון
  securityCheckUrl    String?                           // קישור לתמונה של צ'ק הביטחון
  isContractSigned    Boolean  @default(false)          // האם חוזה נחתם

  // --- היסטוריה ולוגים ---
  createdAt         DateTime @default(now())
  createdBy         String
  updatedAt         DateTime @updatedAt
  updatedBy         String?

  // --- טופס הפקת אירוע ---
  eventForm         EventForm?
}

// מודל לקטגוריות בתפריט
model MenuCategory {
  id     String @id @default(uuid())
  name   String 
  dishes Dish[] 
}

// מודל למנה בודדת בתפריט
model Dish {
  id          String       @id @default(uuid())
  name        String
  description String?
  price       Float?
  categoryId  String
  category    MenuCategory @relation(fields: [categoryId], references: [id])
}

// מודל לתאריכים ואופציות בלוח השנה
model EventDate {
  id              String    @id @default(uuid())
  date            DateTime  @unique
  status          String
  lockedBy        String?
  booking         Booking?
  clientName      String?
  clientPhone     String?
  clientEmail     String?
  optionExpiresAt DateTime?
}

// טופס הפקת אירוע - ממולא חודש לפני האירוע
model EventForm {
  id                  String   @id @default(uuid())
  bookingId           String   @unique
  booking             Booking  @relation(fields: [bookingId], references: [id])

  // פרטי בסיס
  eventTime           String?   // שעת קבלת פנים
  receptionType       String?   // נפרד / מעורב
  finalGuestCount     Int?
  seatingType         String?   // מעורב / נפרד

  // חלוקה (רק אם נפרד)
  menPercent          Int?
  womenPercent        Int?

  // שולחן כבוד
  honorTableCount     Int?

  // עיצוב
  tableclothId        String?   // id של מפה שנבחרה
  napkinId            String?   // id של מפית שנבחרה
  centerpiece         String?   // מרכזי שולחן
  bridgeChair         String?   // כסא כלה

  // ציוד
  hasLighting         Boolean  @default(false)
  hasSoundSystem      Boolean  @default(false)
  hasScreens          Boolean  @default(false)
  hasFireworks        Boolean  @default(false)

  // משמחים
  entertainersBar     Int?     // כמות בר
  entertainersSitting Int?     // כמות ישיבה
  entertainersMen     Int?
  entertainersWomen   Int?

  // צ'ק פיקדון
  depositCheckUrl     String?
  depositCheckStatus  Boolean  @default(false)

  // אקו"ם
  akumCode            String?

  // כשרות
  kashrut             String?  // בד רובין / מחפוד / אחר

  // הערות (ממוספרות - JSON array)
  notes               String?  // JSON string של מערך הערות

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}